# Elasticsearch
ES_HOST=http://localhost:9200
ES_INDEX_REVIEWS=ewallet_reviews
ES_INDEX_EMBEDDINGS=ewallet_embeddings

# Model
MODEL_NAME=indobenchmark/indobert-base-p1
MODEL_OUTPUT_DIR=./models
MAX_LENGTH=256
BATCH_SIZE=16
EPOCHS=5
LEARNING_RATE=2e-5

# API
API_HOST=0.0.0.0
API_PORT=8000

# Scraper
SCRAPER_DEFAULT_COUNT=10000

# HuggingFace
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
HF_SPACE_ID=your-org/e-wallet-sentiment