PORT=3001
DATABASE_URL="postgresql://user:password@localhost:5433/ewallet_sentiment?schema=public"
LEVEL_LOG=info

# JWT SECRETS
JWT_SECRET="super-secret-jwt-key-for-dev"
JWT_REFRESH_SECRET="super-secret-refresh-key-for-dev"
JWT_ACCESS_EXPIRATION="60m"
JWT_REFRESH_EXPIRATION="7d"

# MAIL SERVER
MAIL_TRANSPORT=logger # logger, google, smtp
MAIL_FROM=

## GOOGLE
GOOGLE_MAIL_USER=
GOOGLE_MAIL_APP_PASSWORD=


# SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=

# IMAGE UPLOAD
IMAGE_PROVIDER=local # local, cloudinary
IMAGE_MAX_FILE_SIZE_MB=5
IMAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif

# LOCAL IMAGE STORAGE
IMAGE_LOCAL_UPLOAD_DIR=uploads
IMAGE_LOCAL_SERVE_PATH=/uploads
IMAGE_LOCAL_PUBLIC_BASE_URL=

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=e-wallet-sentiment