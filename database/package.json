{
  "name": "e-wallet-sentiment-database",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "generate": "prisma generate --schema=./schema.prisma",
    "db:push": "prisma db push --schema=./schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=./schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=./schema.prisma",
    "db:seed": "prisma db seed --schema=./schema.prisma"
  },
  "prisma": {
    "seed": "node seeds/index.js"
  },
  "devDependencies": {
    "prisma": "^7.4.1"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "pg": "^8.19.0"
  }
}