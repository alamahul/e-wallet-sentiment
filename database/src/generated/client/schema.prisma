generator client {
  provider = "prisma-client-js"
  output   = "./src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Review {
  review_id              String    @id @db.VarChar(255)
  user_name              String?   @db.VarChar(255)
  user_image             String?   @db.Text
  content                String    @db.Text
  score                  Int?
  thumbs_up_count        Int?
  review_created_version String?   @db.VarChar(100)
  review_datetime        DateTime? @db.Timestamp
  reply_content          String?   @db.Text
  replied_at             DateTime? @db.Timestamp
  app_version            String?   @db.VarChar(100)

  timestamp_unix      BigInt?
  timestamp_formatted String? @db.VarChar(50)
  source              String  @db.VarChar(50)

  is_analyzed      Boolean? @default(false)
  sentiment_result String?  @db.VarChar(20)
  confidence_score Float?

  created_at DateTime? @default(now()) @db.Timestamp

  @@index([is_analyzed], name: "idx_unprocessed_reviews")
  @@index([source, sentiment_result], name: "idx_source_sentiment")
  @@map("reviews")
}
